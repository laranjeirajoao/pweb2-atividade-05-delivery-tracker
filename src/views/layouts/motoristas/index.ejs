<div class="form-buttons" id="botao-cadastro">
  <button type="button"><a href="/painel/motoristas/nova">Cadastrar novo motorista</a></button>
</div>

<table>
  <thead>
    <tr>
      <th>Nome</th>
      <th>CPF</th>
      <th>Placa do Veículo</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% motoristas && motoristas.forEach(item=> { %>
    <tr>
      <td>
        <%= item.nome %>
      </td>
      <td>
        <%= item.cpf %>
      </td>
      <td>
        <%= item.placa_veiculo %>
      </td>
      <td>
        <%= item.status.split("_").join(" ") %>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>