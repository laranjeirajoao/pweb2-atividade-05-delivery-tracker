<%
  const currentPage = Number(page) || 1;
  const lastPage = Number(totalPages) || 1;

  function buildUrl(targetPage) {
    const params = new URLSearchParams();

    if (status) {
      params.set("status", status);
    }

    if (limit) {
      params.set("limit", limit);
    }

    params.set("page", targetPage);

    return `${baseUrl}?${params.toString()}`;
  }
%>


<nav>
  <ul class="pagination">
    <!-- Página anterior -->
    <% if (page> 1) { %>
    <li class="page-item"><a class="page-link" href="<%= buildUrl(currentPage - 1) %>">Página anterior</a>
    </li>
    <% } %>

    <!-- Mostra a pagina atual e quantas paginas tem -->
    <li class="page-item">Página <%= page %> de <%= totalPages %>
    </li>

    <!-- Próxima página -->
    <% if (page < totalPages) { %>
    <li class="page-item"><a class="page-link" href="<%= buildUrl(currentPage + 1) %>">Próxima
        página</a></li>
    <% } %>
  </ul>
</nav>