<div class="form-container">
  <h1>Novo Motorista</h1>

  <!-- Exibição de erros -->
  <% if (erros && erros.length> 0) { %>
  <div class="alert alert-error">
    <ul>
      <% erros.forEach(erro=> { %>
      <li>
        <%= erro %>
      </li>
      <% }); %>
    </ul>
  </div>
  <% } %>

  <form method="POST" action="/painel/motoristas" novalidate>
    <div class="form-group <% if (erros && erros.some(e => e.includes('nome'))) { %>has-error<% } %>">
      <label for="nome">Nome</label>
      <input type="text" id="nome" name="nome" value="<%= dados.nome || '' %>" placeholder="Nome completo" required>
    </div>

    <div class="form-group <% if (erros && erros.some(e => e.includes('cpf'))) { %>has-error<% } %>">
      <label for="cpf">CPF</label>
      <input type="text" id="cpf" name="cpf" value="<%= dados.cpf || '' %>" placeholder="Número do CPF" required>
    </div>

    <div class="form-group">
      <label for="placaVeiculo">Placa do Veículo</label>
      <input type="text" id="placaVeiculo" name="placaVeiculo" value="<%= dados.placaVeiculo || '' %>" placeholder="Placa do veículos" required>
    </div>

    <div class="form-actions">
      <a href="/painel/motoristas" class="btn btn-secondary">Cancelar</a>
      <button type="submit" class="btn btn-primary">Criar Motorista</button>
    </div>
  </form>
</div>