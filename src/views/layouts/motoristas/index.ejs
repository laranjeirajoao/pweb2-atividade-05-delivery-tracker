<a href="/painel/motoristas/nova">Cadastrar novo motorista</a>

<table>
  <tr>
    <th>Nome</th>
    <th>CPF</th>
    <th>Placa do Veículo</th>
    <th>Status</th>
  </tr>
  <% motoristas && motoristas.forEach(item=> { %>
  <tr>
    <td>
      <%= item.nome %>
    </td>
    <td>
      <%= item.cpf %>
    </td>
    <td>
      <%= item.placa_veiculo %>
    </td>
    <td>
      <%= item.status.split("_").join(" ") %>
    </td>
  </tr>
  <% }); %>
</table>